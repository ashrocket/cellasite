---
import '../styles/global.scss';

interface Props {
  title?: string;
  activePage?: string;
}

const { title = 'CELLA', activePage = '' } = Astro.props;

const navItems = [
  { label: 'PROJECTS', href: '/projects' },
  { label: 'GRAPHICS', href: '/graphics' },
  { label: 'MOTION', href: '/motion' },
  { label: 'CREATIVE DIR', href: '/creative-direction' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="CELLA — Graphic Designer & Creative Strategist" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="logo">
        <!-- Placeholder for hand-drawn CELLA logo SVG -->
        <span class="logo-text">CELLA</span>
      </a>
      <nav class="main-nav">
        {navItems.map(item => (
          <a
            href={item.href}
            class:list={['nav-item', { active: activePage === item.label }]}
          >
            <span class="nav-frame">
              <span class="nav-label">{item.label}</span>
            </span>
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>
  </body>
</html>

<style lang="scss">
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    pointer-events: none;

    > * {
      pointer-events: auto;
    }
  }

  .logo {
    display: block;
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 2.5rem;
    font-weight: bold;
    letter-spacing: 0.05em;
    opacity: 0.8;
  }

  .main-nav {
    display: flex;
    gap: 0.5rem;
    align-items: flex-start;
  }

  .nav-item {
    display: block;
    transition: opacity 0.2s;

    &:hover {
      opacity: 0.7;
    }
  }

  .nav-frame {
    display: inline-block;
    border: 1.5px solid var(--color-text);
    border-radius: 4px;
    padding: 0.5rem 1.25rem;
    position: relative;
  }

  .nav-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .nav-item.active .nav-frame {
    border-color: var(--color-accent);
  }
</style>
